CLIP_MIN_DURATION=20
CLIP_MAX_DURATION=60
CLIP_TARGET_DURATION=40
NUM_CLIPS=5
MIN_GAP_SECONDS=45
PEAK_PROMINENCE=0.15
ENERGY_WEIGHT=0.7
APPLAUSE_WEIGHT=0.3
SAMPLE_RATE=16000
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
VIDEO_CRF=18
WORK_DIR=./work
OUTPUT_DIR=./output

# --- Señal de chat: en standby, no implementada ---
# USE_CHAT_SIGNAL=false

# --- Capa de IA opcional (Fase 2) ---
USE_AI_LAYER=false
LLM_PROVIDER=gemini
GEMINI_API_KEY=              # obtener en https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-3.5-flash
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=es          # fija el idioma de transcripción (evita que Whisper autodetecte mal con intros instrumentales/aplausos sin habla); "auto" o vacío = autodetectar
LLM_TIMEOUT_SECONDS=120
AI_CANDIDATE_POOL_MULTIPLIER=3
MAX_TRANSCRIPT_CHARS=20000
BURN_SUBTITLES=true
