CLIP_MIN_DURATION=20
CLIP_MAX_DURATION=60
CLIP_TARGET_DURATION=40
NUM_CLIPS=20             
MIN_GAP_SECONDS=45
PEAK_PROMINENCE=0.03
ENERGY_WEIGHT=0.7
APPLAUSE_WEIGHT=0.3
SAMPLE_RATE=16000
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
VIDEO_CRF=18
WORK_DIR=./work
OUTPUT_DIR=./output

# --- Capa de IA opcional (Fase 2) ---
USE_AI_LAYER=false
LLM_PROVIDER=gemini
GEMINI_API_KEY=              # obtener en https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-3.5-flash
WHISPER_MODEL_SIZE=small     # con directos cercanos a las 4h, transcribir tarda bastante
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=es          # fija el idioma de transcripción (evita que Whisper autodetecte mal el idioma)
LLM_TIMEOUT_SECONDS=180    
AI_CANDIDATE_POOL_MULTIPLIER=3
MAX_TRANSCRIPT_CHARS=45000 
BURN_SUBTITLES=true

# --- Publicación automática (Fase 3) ---
# Redes de seguridad: además de elegir la plataforma como argumento
# (`clipengine publish tiktok|instagram`), estos flags deben estar en true
# o el comando se niega a publicar. Ambos en false por default.
PUBLISH_TIKTOK=false
PUBLISH_INSTAGRAM=false

# Credenciales de la app (estáticas, ver README > Publicación automática para cómo
# obtenerlas). Los tokens de usuario (access/refresh) NO van acá — se generan con
# `clipengine auth <plataforma>` y se guardan aparte, ver PUBLISH_TOKEN_DIR.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

PUBLISH_POLL_INTERVAL_SECONDS=15   # cada cuánto se consulta el estado de la subida
PUBLISH_POLL_TIMEOUT_SECONDS=300   # máximo a esperar antes de considerarlo fallido
# PUBLISH_TOKEN_DIR=~/.config/clipengine/tokens   # default si se deja sin definir

# Puerto local para el callback de `clipengine auth <plataforma>` — debe coincidir
# EXACTO con el "redirect URI" (http://localhost:8912/callback) que registres en el
# dashboard de TikTok for Developers y de Meta for Developers.
PUBLISH_OAUTH_PORT=8912
