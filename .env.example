# Calibrados para directos de 1-4 horas. Para videos cortos (unos pocos minutos),
# ver la sección "Nota importante sobre los defaults" del README.
CLIP_MIN_DURATION=20
CLIP_MAX_DURATION=60
CLIP_TARGET_DURATION=40
NUM_CLIPS=8                  # más candidatos que en un directo de 1h, para no perder
                              # buenos momentos repartidos a lo largo de hasta 4h
MIN_GAP_SECONDS=45
PEAK_PROMINENCE=0.15
ENERGY_WEIGHT=0.7
APPLAUSE_WEIGHT=0.3
SAMPLE_RATE=16000
OUTPUT_WIDTH=1080
OUTPUT_HEIGHT=1920
VIDEO_CRF=18
WORK_DIR=./work
OUTPUT_DIR=./output

# --- Señal de chat: en standby, no implementada ---
# USE_CHAT_SIGNAL=false

# --- Capa de IA opcional (Fase 2) ---
USE_AI_LAYER=false
LLM_PROVIDER=gemini
GEMINI_API_KEY=              # obtener en https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-3.5-flash
WHISPER_MODEL_SIZE=small     # con directos cercanos a las 4h, transcribir tarda bastante
                              # en CPU; si es muy lento, "base" o "tiny" son más rápidos
                              # a cambio de menos precisión
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=es          # fija el idioma de transcripción (evita que Whisper autodetecte mal con intros instrumentales/aplausos sin habla); "auto" o vacío = autodetectar
LLM_TIMEOUT_SECONDS=180      # algo más de margen que en un directo corto, por si el
                              # prompt (transcripción + candidatos) es más grande
AI_CANDIDATE_POOL_MULTIPLIER=3
MAX_TRANSCRIPT_CHARS=45000   # una transcripción de hasta 4h puede ser bastante más
                              # larga que la de 1h original; subido para no truncarla
                              # de más (igual se trunca si hace falta, no rompe nada)
BURN_SUBTITLES=true
